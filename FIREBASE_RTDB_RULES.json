{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "profile": {
          ".validate": "newData.hasChildren(['uid', 'email'])"
        },
        "history": {
          "$historyId": {
            ".validate": "newData.hasChildren(['eventType', 'clientTimestamp']) && newData.hasChild('serverTimestamp') === false"
          }
        }
      }
    },
    ".read": false,
    ".write": false
  }
}
